# Comma-separated parent origins allowed to postMessage into this app.
# When unset or empty, the app defaults to http://ui (production kiosk parent).
# Example includes common local dev origins after the kiosk default:
NEXT_PUBLIC_ALLOWED_PARENT_ORIGINS=http://ui,http://localhost:3000,http://127.0.0.1:5173

NEXT_PAGE_TITLE="Watchly Devkit"
